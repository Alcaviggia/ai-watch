{
  "name": "montre",
  "description": "Give your AI a watch — local time context for AI chat interfaces. Internal codename; store name is \"AI-Watch Clock\", display brand is \"AI-Watch\" (src/shared/brand.ts).",
  "private": true,
  "version": "1.0.26",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@wxt-dev/module-svelte": "^2.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.3.0",
    "svelte": "^5.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^3.0.0",
    "wxt": "^0.20.0"
  }
}
